    <!-- DOSSIER CLIENT MODAL (Create / Edit) -->
    <div class="modal-overlay" id="dossier-modal">
        <div class="modal" style="max-width:750px;">
            <div class="modal-header">
                <h2 id="dossier-modal-title">Nouveau dossier client</h2>
                <button class="modal-close" onclick="closeModal('dossier-modal')">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                </button>
            </div>
            <div class="modal-body">
                <div class="form-row">
                    <div class="form-group" style="flex:2;">
                        <label>Raison sociale <span style="color:var(--danger);">*</span></label>
                        <input type="text" class="form-control" id="dossier-name" placeholder="Nom de l'entreprise cliente">
                    </div>
                    <div class="form-group">
                        <label>Forme juridique</label>
                        <select class="form-control" id="dossier-forme">
                            <option value="">— Sélectionner —</option>
                            <option value="SARL">SARL</option>
                            <option value="SA">SA</option>
                            <option value="SNC">SNC</option>
                            <option value="SCS">SCS</option>
                            <option value="SCA">SCA</option>
                            <option value="Auto-entrepreneur">Auto-entrepreneur</option>
                            <option value="Cooperative">Coopérative</option>
                        </select>
                    </div>
                </div>

                <h3 style="font-size:0.9rem;font-weight:700;color:var(--charcoal);margin:1rem 0 0.75rem;">Identifiants légaux (Maroc)</h3>
                <div class="form-row">
                    <div class="form-group">
                        <label>ICE</label>
                        <input type="text" class="form-control" id="dossier-ice" placeholder="Identifiant Commun de l'Entreprise">
                    </div>
                    <div class="form-group">
                        <label>IF (Identifiant Fiscal)</label>
                        <input type="text" class="form-control" id="dossier-idf" placeholder="Identifiant Fiscal">
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>RC (Registre Commerce)</label>
                        <input type="text" class="form-control" id="dossier-rc" placeholder="Numéro RC">
                    </div>
                    <div class="form-group">
                        <label>CNSS</label>
                        <input type="text" class="form-control" id="dossier-cnss" placeholder="Numéro CNSS">
                    </div>
                </div>

                <h3 style="font-size:0.9rem;font-weight:700;color:var(--charcoal);margin:1rem 0 0.75rem;">Coordonnées</h3>
                <div class="form-group">
                    <label>Adresse</label>
                    <input type="text" class="form-control" id="dossier-address" placeholder="Adresse complète">
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>Ville</label>
                        <input type="text" class="form-control" id="dossier-city" placeholder="Ville">
                    </div>
                    <div class="form-group">
                        <label>Téléphone</label>
                        <input type="text" class="form-control" id="dossier-phone" placeholder="+212 5XX XX XX XX">
                    </div>
                </div>
                <div class="form-group">
                    <label>Email du client</label>
                    <input type="email" class="form-control" id="dossier-email" placeholder="contact@client.ma" oninput="onDossierEmailChange(this.value)">
                </div>

                <!-- Invitation section — shown when email is filled -->
                <div id="dossier-invitation-section" style="background:#f0fdf4;border:1px solid #bbf7d0;border-radius:10px;padding:0.9rem 1rem;margin-top:-0.25rem;margin-bottom:0.5rem;display:none;">
                    <label style="display:flex;align-items:flex-start;gap:0.6rem;cursor:pointer;">
                        <input type="checkbox" id="dossier-send-invite" checked style="margin-top:2px;cursor:pointer;accent-color:#059669;flex-shrink:0;">
                        <div>
                            <span style="font-size:0.875rem;font-weight:600;color:#065f46;">Envoyer une invitation au client</span>
                            <p style="font-size:0.78rem;color:#059669;margin-top:0.15rem;line-height:1.4;">Un email avec un lien de création de compte sera envoyé à cette adresse.</p>
                        </div>
                    </label>
                </div>

                <!-- Invitation status (edit mode) -->
                <div id="dossier-invitation-status" style="display:none;margin-top:-0.25rem;margin-bottom:0.5rem;"></div>

                <h3 style="font-size:0.9rem;font-weight:700;color:var(--charcoal);margin:1rem 0 0.75rem;">Affectation & Comptabilité</h3>
                <div class="form-row">
                    <div class="form-group">
                        <label>Collaborateur</label>
                        <input type="text" class="form-control" id="dossier-collaborateur" placeholder="Nom du collaborateur">
                        <select class="form-control" id="dossier-collaborateur-id" style="margin-top:0.35rem;font-size:0.82rem;">
                            <option value="">— Assigner un membre (RBAC) —</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Chef de mission</label>
                        <input type="text" class="form-control" id="dossier-chef" placeholder="Nom du chef de mission">
                        <select class="form-control" id="dossier-chef-id" style="margin-top:0.35rem;font-size:0.82rem;">
                            <option value="">— Assigner un membre (RBAC) —</option>
                        </select>
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>Expert-comptable</label>
                        <input type="text" class="form-control" id="dossier-expert-comptable" placeholder="Nom de l'expert-comptable">
                    </div>
                    <div class="form-group">
                        <label>Pilote PA</label>
                        <input type="text" class="form-control" id="dossier-pilote-pa" placeholder="Nom du pilote PA (optionnel)">
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>Abonnement</label>
                        <select class="form-control" id="dossier-abonnement">
                            <option value="Collaboratif">Collaboratif</option>
                            <option value="Premium internalisé">Premium internalisé</option>
                            <option value="Premium externalisé">Premium externalisé</option>
                            <option value="Essentiel">Essentiel</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Type de comptabilité</label>
                        <select class="form-control" id="dossier-type-comptabilite">
                            <option value="Engagement">Engagement</option>
                            <option value="Tresorerie">Trésorerie</option>
                        </select>
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>Fréquence TVA</label>
                        <select class="form-control" id="dossier-frequence-tva">
                            <option value="Mensuelle">Mensuelle</option>
                            <option value="Trimestrielle">Trimestrielle</option>
                            <option value="Annuelle">Annuelle</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Statut</label>
                        <select class="form-control" id="dossier-statut">
                            <option value="actif">Actif</option>
                            <option value="archive">Archivé</option>
                        </select>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" onclick="closeModal('dossier-modal')">Annuler</button>
                <button class="btn btn-primary" onclick="saveDossier()">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17,21 17,13 7,13 7,21"/></svg>
                    Enregistrer
                </button>
            </div>
        </div>
    </div>

    <!-- INVOICE MODAL -->
    <div class="modal-overlay" id="invoice-modal">
        <div class="modal" style="max-width: 860px;">
            <div class="modal-header">
                <h2 id="inv-modal-title">Nouvelle Facture</h2>
                <button class="modal-close" onclick="closeModal('invoice-modal')">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                </button>
            </div>
            <div class="modal-body">
                <div class="form-row">
                    <div class="form-group">
                        <label>Type de Facture</label>
                        <select class="form-control" id="inv-type" onchange="onInvoiceTypeChange()">
                            <option value="vente">Facture de vente</option>
                            <option value="achat">Facture d'achat</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Date</label>
                        <input type="date" class="form-control" id="inv-date">
                    </div>
                    <div class="form-group">
                        <label>Date d'échéance</label>
                        <input type="date" class="form-control" id="inv-due-date">
                    </div>
                </div>

                <!-- Client selector (new vente clients) -->
                <div class="form-group" id="inv-client-group">
                    <label>Client <span id="inv-ice-required-indicator" style="color:#ef4444;font-size:0.78rem;display:none;">— ICE obligatoire pour les factures de vente</span></label>
                    <div style="display:flex;gap:0.5rem;align-items:center;">
                        <select class="form-control" id="inv-client" onchange="onInvoiceClientChange()" style="flex:1;">
                            <option value="">-- Sélectionner un client --</option>
                        </select>
                        <button type="button" class="btn btn-secondary btn-sm" onclick="openInlineClientModalForInvoice()" title="Nouveau client" style="white-space:nowrap;flex-shrink:0;">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="13" height="13"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                            Nouveau
                        </button>
                    </div>
                </div>

                <!-- Contact sub-selector -->
                <div class="form-row">
                    <div class="form-group" id="inv-contact-group">
                        <label>Contact</label>
                        <div style="display:flex;gap:0.5rem;align-items:center;">
                            <select class="form-control" id="inv-contact" style="flex:1;">
                                <option value="">-- Sélectionner un contact --</option>
                            </select>
                            <button type="button" class="btn btn-secondary btn-sm" onclick="openInlineContactModalForInvoice()" title="Nouveau contact" style="white-space:nowrap;flex-shrink:0;" id="inv-new-contact-btn">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="13" height="13"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                                Nouveau
                            </button>
                        </div>
                    </div>
                    <div class="form-group">
                        <label>ICE du Client <span style="color:#ef4444;font-size:0.78rem;" id="inv-ice-label-required"></span></label>
                        <input type="text" class="form-control" id="inv-ice" placeholder="ICE client (auto-rempli depuis la fiche client)" oninput="onInvoiceIceInput()">
                    </div>
                </div>

                <!-- ICE error banner -->
                <div id="inv-ice-error" style="display:none;background:#fef2f2;border:1px solid #fca5a5;border-radius:8px;padding:0.75rem 1rem;margin-bottom:1rem;font-size:0.85rem;color:#dc2626;">
                    <strong>ICE obligatoire :</strong> L'ICE est requis pour émettre une facture de vente.
                    <span id="inv-ice-client-link" style="display:none;"> — <a href="#" onclick="closeModal('invoice-modal');navigate('vente-clients');return false;" style="color:#dc2626;text-decoration:underline;">Compléter la fiche client</a></span>
                </div>

                <h3 style="font-size: 0.9rem; font-weight: 700; margin: 1.25rem 0 0.75rem; color: var(--charcoal);">Lignes de facturation</h3>
                <div style="overflow-x: auto;">
                    <table class="line-items-table" id="invoice-lines-table">
                        <thead>
                            <tr>
                                <th style="width: 30%;">Produit / Description</th>
                                <th style="width: 12%;">Quantité</th>
                                <th style="width: 18%;">Prix Unitaire HT</th>
                                <th style="width: 12%;">TVA</th>
                                <th style="width: 13%;">Total HT</th>
                                <th style="width: 5%;"></th>
                            </tr>
                        </thead>
                        <tbody id="invoice-lines">
                            <tr>
                                <td>
                                    <div style="display:flex;gap:0.3rem;align-items:center;">
                                        <input type="text" placeholder="Description de l'article" oninput="calculateInvoiceTotals()" style="flex:1;min-width:0;">
                                        <button type="button" class="btn btn-secondary btn-sm" onclick="openProductPickerForLine(this)" title="Choisir produit" style="flex-shrink:0;padding:0.2rem 0.4rem;">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="11" height="11"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
                                        </button>
                                    </div>
                                </td>
                                <td><input type="number" value="1" min="0" step="1" oninput="calculateInvoiceTotals()"></td>
                                <td><input type="number" value="0" min="0" step="0.01" oninput="calculateInvoiceTotals()"></td>
                                <td>
                                    <select onchange="calculateInvoiceTotals()">
                                        <option value="20">20%</option>
                                        <option value="14">14%</option>
                                        <option value="10">10%</option>
                                        <option value="7">7%</option>
                                        <option value="0">0%</option>
                                    </select>
                                </td>
                                <td><span class="number-cell">0,00</span></td>
                                <td><button class="remove-line" onclick="removeInvoiceLine(this)" title="Supprimer">&times;</button></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
                <div style="display:flex;gap:0.5rem;margin-top:0.5rem;align-items:center;">
                    <button class="btn btn-secondary btn-sm" onclick="addInvoiceLine()">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                        Ajouter une ligne
                    </button>
                    <button class="btn btn-secondary btn-sm" onclick="openInlineProductModalForInvoice()" id="inv-add-product-btn">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                        Nouveau produit
                    </button>
                </div>

                <div class="invoice-totals" id="invoice-totals">
                    <div class="total-row">
                        <span class="total-label">Sous-total HT</span>
                        <span class="total-value" id="inv-subtotal">0,00 MAD</span>
                    </div>
                    <div class="total-row">
                        <span class="total-label">TVA</span>
                        <span class="total-value" id="inv-tva-total">0,00 MAD</span>
                    </div>
                    <div class="total-row grand-total">
                        <span class="total-label">Total TTC</span>
                        <span class="total-value" id="inv-total">0,00 MAD</span>
                    </div>
                </div>

                <div class="form-group" style="margin-top: 1rem;">
                    <label>Notes</label>
                    <textarea class="form-control" id="inv-notes" rows="2" placeholder="Notes ou conditions..."></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" onclick="closeModal('invoice-modal')">Annuler</button>
                <button class="btn btn-secondary" id="inv-save-devis-btn" onclick="saveInvoiceAsDevis()" style="display:none;border-color:#f59e0b;color:#d97706;">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2"/><rect x="9" y="3" width="6" height="4" rx="1"/></svg>
                    Enregistrer comme devis
                </button>
                <button class="btn btn-primary" onclick="saveInvoice()">Créer la Facture</button>
            </div>
        </div>
    </div>

    <!-- CANCEL INVOICE CONFIRMATION MODAL -->
    <div class="modal-overlay" id="cancel-invoice-modal">
        <div class="modal" style="max-width: 480px;">
            <div class="modal-header">
                <h2>Annuler la facture</h2>
                <button class="modal-close" onclick="closeModal('cancel-invoice-modal')">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                </button>
            </div>
            <div class="modal-body">
                <div style="background:#fef2f2;border:1px solid #fca5a5;border-radius:8px;padding:1rem;margin-bottom:1rem;">
                    <p style="color:#dc2626;font-weight:600;margin-bottom:0.5rem;">⚠️ Cette action est irréversible</p>
                    <p style="font-size:0.875rem;color:#6b7280;">L'annulation crée automatiquement une <strong>facture d'avoir</strong> (AV-YYYY-NNN) avec des écritures comptables inverses. La facture originale sera marquée <strong>Annulée</strong>.</p>
                </div>
                <p style="font-size:0.875rem;color:#374151;">Facture : <strong id="cancel-invoice-number"></strong></p>
                <p style="font-size:0.875rem;color:#374151;">Montant TTC : <strong id="cancel-invoice-amount"></strong></p>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" onclick="closeModal('cancel-invoice-modal')">Retour</button>
                <button class="btn btn-danger" id="cancel-invoice-confirm-btn" onclick="executeCancelInvoice()" style="background:#dc2626;border-color:#dc2626;color:white;">
                    Confirmer l'annulation
                </button>
            </div>
        </div>
    </div>

    <!-- PRODUCT PICKER MODAL (for invoice lines) -->
    <div class="modal-overlay" id="product-picker-modal">
        <div class="modal" style="max-width: 540px;">
            <div class="modal-header">
                <h2>Sélectionner un produit</h2>
                <button class="modal-close" onclick="closeModal('product-picker-modal')">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                </button>
            </div>
            <div class="modal-body">
                <input type="text" class="form-control" id="product-picker-search" placeholder="Rechercher un produit..." oninput="filterProductPicker(this.value)" style="margin-bottom:0.75rem;">
                <div id="product-picker-list" style="max-height:320px;overflow-y:auto;"></div>
            </div>
        </div>
    </div>

    <!-- OCR IMPORT MODAL -->
    <div class="modal-overlay" id="ocr-import-modal">
        <div class="modal" style="max-width: 560px;">
            <div class="modal-header">
                <h2>Importer une Facture Fournisseur</h2>
                <button class="modal-close" onclick="closeModal('ocr-import-modal')">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                </button>
            </div>
            <div class="modal-body">
                <!-- Step 1: Upload -->
                <div id="ocr-step-upload">
                    <div id="ocr-drop-zone" style="border: 2px dashed var(--border); border-radius: 12px; padding: 2.5rem 1.5rem; text-align: center; cursor: pointer; transition: all 0.2s; background: var(--sand);"
                         onclick="document.getElementById('ocr-file-input').click()"
                         ondragover="event.preventDefault(); this.style.borderColor='var(--emerald)'; this.style.background='var(--success-light)'"
                         ondragleave="this.style.borderColor='var(--border)'; this.style.background='var(--sand)'"
                         ondrop="event.preventDefault(); this.style.borderColor='var(--border)'; this.style.background='var(--sand)'; handleOCRDrop(event)">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="48" height="48" style="color: var(--emerald); margin-bottom: 1rem;"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14,2 14,8 20,8"/><line x1="12" y1="12" x2="12" y2="18"/><line x1="9" y1="15" x2="15" y2="15"/></svg>
                        <p style="font-weight: 600; color: var(--charcoal); margin-bottom: 0.4rem;">Glissez votre facture ici</p>
                        <p style="color: var(--muted); font-size: 0.875rem; margin-bottom: 0.75rem;">ou cliquez pour selectionner un fichier</p>
                        <p style="font-size: 0.78rem; color: var(--muted);">JPG, PNG, WEBP &bull; Max 10 MB &bull; PDF converti automatiquement</p>
                        <input type="file" id="ocr-file-input" accept="image/*,.pdf" style="display:none" onchange="handleOCRFileSelect(this)">
                    </div>
                    <div style="display:flex; align-items:center; gap:1rem; margin: 1.25rem 0;">
                        <hr style="flex:1; border:none; border-top: 1px solid var(--border);">
                        <span style="color:var(--muted); font-size:0.85rem;">ou</span>
                        <hr style="flex:1; border:none; border-top: 1px solid var(--border);">
                    </div>
                    <button class="btn btn-secondary" style="width:100%;" onclick="closeModal('ocr-import-modal'); openInvoiceModal('purchase');">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                        Saisie manuelle d'achat
                    </button>
                </div>
                <!-- Step 2: Processing -->
                <div id="ocr-step-processing" style="display:none; text-align:center; padding: 2rem;">
                    <div class="spinner" style="width:48px; height:48px; border-width:4px; margin: 0 auto 1.5rem;"></div>
                    <p style="font-weight: 600; color: var(--charcoal); margin-bottom: 0.4rem;">Extraction en cours...</p>
                    <p style="color: var(--muted); font-size:0.875rem;">L'IA analyse votre facture. Quelques secondes...</p>
                </div>
                <!-- Step 3: Error -->
                <div id="ocr-step-error" style="display:none; text-align:center; padding: 2rem;">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="48" height="48" style="color: var(--danger); margin-bottom: 1rem;"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
                    <p style="font-weight: 600; color: var(--charcoal); margin-bottom: 0.5rem;" id="ocr-error-msg">Erreur lors de l'extraction</p>
                    <button class="btn btn-secondary" onclick="resetOCRModal()">Reessayer</button>
                </div>
            </div>
        </div>
    </div>

    <!-- EXPENSE MODAL -->
    <div class="modal-overlay" id="expense-modal">
        <div class="modal" style="max-width: 550px;">
            <div class="modal-header">
                <h2>Nouvelle facture fournisseur</h2>
                <button class="modal-close" onclick="closeModal('expense-modal')">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                </button>
            </div>
            <div class="modal-body">
                <div class="form-row">
                    <div class="form-group">
                        <label>Date</label>
                        <input type="date" class="form-control" id="exp-date">
                    </div>
                    <div class="form-group">
                        <label>Montant HT</label>
                        <input type="number" class="form-control" id="exp-amount" min="0" step="0.01" placeholder="0,00">
                    </div>
                </div>
                <div class="form-group">
                    <label>Description</label>
                    <input type="text" class="form-control" id="exp-description" placeholder="Description de la depense">
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>Compte de Charge</label>
                        <select class="form-control" id="exp-account">
                            <option value="">-- Selectionner --</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Taux TVA</label>
                        <select class="form-control" id="exp-tva">
                            <option value="20">20%</option>
                            <option value="14">14%</option>
                            <option value="10">10%</option>
                            <option value="7">7%</option>
                            <option value="0">0%</option>
                        </select>
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>Mode de Paiement</label>
                        <select class="form-control" id="exp-payment-method">
                            <option value="virement">Virement</option>
                            <option value="cheque">Cheque</option>
                            <option value="especes">Especes</option>
                            <option value="carte">Carte bancaire</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Categorie</label>
                        <select class="form-control" id="exp-category">
                            <option value="fournitures">Fournitures</option>
                            <option value="services">Services</option>
                            <option value="loyer">Loyer</option>
                            <option value="salaires">Salaires</option>
                            <option value="transport">Transport</option>
                            <option value="telecom">Telecommunication</option>
                            <option value="autres">Autres</option>
                        </select>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" onclick="closeModal('expense-modal')">Annuler</button>
                <button class="btn btn-primary" onclick="saveExpense()">Enregistrer</button>
            </div>
        </div>
    </div>

    <!-- IMPORT FACTURES MODAL -->
    <div class="modal-overlay" id="import-factures-modal">
        <div class="modal" style="max-width:600px;">
            <div class="modal-header">
                <h2 style="font-size:1.1rem;">Importer des factures fournisseurs</h2>
                <button class="modal-close" onclick="closeModal('import-factures-modal')">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                </button>
            </div>
            <div class="modal-body">
                <!-- Drop zone -->
                <div id="import-dropzone" onclick="document.getElementById('import-files-input').click()"
                    ondragover="event.preventDefault();this.style.background='#ecfdf5';this.style.borderColor='#059669';"
                    ondragleave="this.style.background='#f9fafb';this.style.borderColor='#d1d5db';"
                    ondrop="handleImportDrop(event)"
                    style="border:2px dashed #d1d5db;border-radius:8px;padding:2.5rem 1.5rem;text-align:center;cursor:pointer;background:#f9fafb;transition:all 0.15s;">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="40" height="40" style="color:#9ca3af;margin-bottom:0.75rem;"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                    <p style="margin:0 0 0.25rem;font-weight:600;color:#374151;">Glissez vos factures ici</p>
                    <p style="margin:0;font-size:0.82rem;color:#6b7280;">ou cliquez pour sélectionner des fichiers (PDF, JPG, PNG)</p>
                    <p style="margin:0.5rem 0 0;font-size:0.75rem;color:#9ca3af;">Jusqu'à 25 fichiers · 3MB max par fichier</p>
                </div>
                <input type="file" id="import-files-input" multiple accept=".pdf,.jpg,.jpeg,.png,image/*,application/pdf" style="display:none;" onchange="handleImportFilesSelected(this.files)">

                <!-- Selected files list -->
                <div id="import-files-list" style="margin-top:1rem;max-height:200px;overflow-y:auto;display:none;"></div>

                <!-- Progress bar -->
                <div id="import-progress-wrap" style="display:none;margin-top:1rem;">
                    <div style="display:flex;justify-content:space-between;font-size:0.82rem;color:#374151;margin-bottom:0.4rem;">
                        <span>Traitement en cours...</span>
                        <span id="import-progress-text">0 / 0</span>
                    </div>
                    <div style="background:#e5e7eb;border-radius:999px;height:6px;overflow:hidden;">
                        <div id="import-progress-bar" style="background:#059669;height:6px;width:0%;transition:width 0.3s;"></div>
                    </div>
                </div>

                <!-- Results summary -->
                <div id="import-results-summary" style="display:none;margin-top:1rem;padding:0.75rem 1rem;border-radius:6px;background:#f0fdf4;border:1px solid #bbf7d0;font-size:0.85rem;color:#065f46;"></div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" onclick="closeModal('import-factures-modal')">Fermer</button>
                <button id="import-btn" class="btn btn-primary" onclick="startImportFactures()" style="background:#059669;border-color:#059669;">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                    Lancer l'import
                </button>
            </div>
        </div>
    </div>

    <!-- JOURNAL ENTRY MODAL -->
    <div class="modal-overlay" id="journal-entry-modal">
        <div class="modal" style="max-width: 800px;">
            <div class="modal-header">
                <h2>Nouvelle Ecriture Comptable</h2>
                <button class="modal-close" onclick="closeModal('journal-entry-modal')">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                </button>
            </div>
            <div class="modal-body">
                <div class="form-row">
                    <div class="form-group">
                        <label>Date</label>
                        <input type="date" class="form-control" id="je-date">
                    </div>
                    <div class="form-group">
                        <label>Type de Journal</label>
                        <select class="form-control" id="je-type">
                            <option value="OD">Operations Diverses</option>
                            <option value="AC">Achats</option>
                            <option value="VE">Ventes</option>
                            <option value="BQ">Banque</option>
                            <option value="CA">Caisse</option>
                        </select>
                    </div>
                </div>
                <div class="form-group">
                    <label>Libelle</label>
                    <input type="text" class="form-control" id="je-description" placeholder="Description de l'ecriture">
                </div>

                <h3 style="font-size: 0.9rem; font-weight: 700; margin: 1.25rem 0 0.75rem; color: var(--charcoal);">Lignes d'ecriture</h3>
                <div style="overflow-x: auto;">
                    <table class="journal-entry-lines" id="je-lines-table">
                        <thead>
                            <tr>
                                <th style="width: 35%;">Compte</th>
                                <th style="width: 25%;">Libelle</th>
                                <th style="width: 15%;">Debit</th>
                                <th style="width: 15%;">Credit</th>
                                <th style="width: 10%;"></th>
                            </tr>
                        </thead>
                        <tbody id="je-lines">
                            <tr>
                                <td><select onchange="updateJournalBalance()"><option value="">-- Compte --</option></select></td>
                                <td><input type="text" placeholder="Libelle"></td>
                                <td><input type="number" min="0" step="0.01" value="" placeholder="0,00" oninput="updateJournalBalance()"></td>
                                <td><input type="number" min="0" step="0.01" value="" placeholder="0,00" oninput="updateJournalBalance()"></td>
                                <td><button class="remove-line" onclick="removeJournalLine(this)">&times;</button></td>
                            </tr>
                            <tr>
                                <td><select onchange="updateJournalBalance()"><option value="">-- Compte --</option></select></td>
                                <td><input type="text" placeholder="Libelle"></td>
                                <td><input type="number" min="0" step="0.01" value="" placeholder="0,00" oninput="updateJournalBalance()"></td>
                                <td><input type="number" min="0" step="0.01" value="" placeholder="0,00" oninput="updateJournalBalance()"></td>
                                <td><button class="remove-line" onclick="removeJournalLine(this)">&times;</button></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
                <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 0.75rem;">
                    <button class="btn btn-secondary btn-sm" onclick="addJournalLine()">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                        Ajouter une ligne
                    </button>
                    <div class="balance-indicator balanced" id="je-balance-indicator">
                        Equilibre: 0,00 MAD
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" onclick="closeModal('journal-entry-modal')">Annuler</button>
                <button class="btn btn-primary" id="je-submit-btn" onclick="saveJournalEntry()">Enregistrer</button>
            </div>
        </div>
    </div>

    <!-- NEW MESSAGE MODAL -->
    <div class="modal-overlay" id="new-message-modal">
        <div class="modal" style="max-width:560px;">
            <div class="modal-header">
                <h2>Nouveau message</h2>
                <button class="modal-close" onclick="closeModal('new-message-modal')">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                </button>
            </div>
            <div class="modal-body">
                <div class="form-group">
                    <label>Type de message</label>
                    <select class="form-control" id="msg-type">
                        <option value="message">Message libre</option>
                        <option value="demande">Demande de justificatif</option>
                        <option value="document">Notification document</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>Message <span style="color:var(--danger);">*</span></label>
                    <textarea class="form-control" id="msg-content" rows="5" placeholder="Saisissez votre message..."></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" onclick="closeModal('new-message-modal')">Annuler</button>
                <button class="btn btn-primary" onclick="saveNewMessage()">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="15" height="15"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
                    Envoyer
                </button>
            </div>
        </div>
    </div>

    <!-- UPLOAD DOCUMENT MODAL -->
    <div class="modal-overlay" id="upload-document-modal">
        <div class="modal" style="max-width:540px;">
            <div class="modal-header">
                <h2>Déposer un document</h2>
                <button class="modal-close" onclick="closeModal('upload-document-modal')">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                </button>
            </div>
            <div class="modal-body">
                <div id="doc-drop-zone" style="border:2px dashed var(--border);border-radius:12px;padding:2rem 1.5rem;text-align:center;cursor:pointer;transition:all 0.2s;background:var(--sand);"
                     onclick="document.getElementById('doc-file-input').click()"
                     ondragover="event.preventDefault();this.style.borderColor='var(--emerald)';this.style.background='var(--success-light)'"
                     ondragleave="this.style.borderColor='var(--border)';this.style.background='var(--sand)'"
                     ondrop="event.preventDefault();this.style.borderColor='var(--border)';this.style.background='var(--sand)';handleDocDrop(event)">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="40" height="40" style="color:var(--emerald);margin-bottom:0.75rem;"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                    <p style="font-weight:600;color:var(--charcoal);margin-bottom:0.3rem;">Glissez votre fichier ici</p>
                    <p style="font-size:0.82rem;color:var(--muted);">ou cliquez pour sélectionner (PDF, JPG, PNG, ZIP — max 15 Mo)</p>
                </div>
                <input type="file" id="doc-file-input" style="display:none;" accept=".pdf,.jpg,.jpeg,.png,.zip,.xlsx,.xls,.doc,.docx" onchange="handleDocFileSelect(this)">
                <div id="doc-selected-file" style="display:none;margin-top:1rem;padding:0.75rem 1rem;background:var(--success-light);border:1px solid #86efac;border-radius:8px;display:flex;align-items:center;gap:0.75rem;">
                    <svg viewBox="0 0 24 24" fill="none" stroke="var(--emerald)" stroke-width="2" width="18" height="18"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/></svg>
                    <span id="doc-selected-name" style="font-size:0.85rem;font-weight:600;color:var(--charcoal);flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"></span>
                </div>
                <div class="form-row" style="margin-top:1rem;">
                    <div class="form-group">
                        <label>Catégorie</label>
                        <select class="form-control" id="doc-category">
                            <option value="facture">Facture</option>
                            <option value="releve_bancaire">Relevé bancaire</option>
                            <option value="justificatif">Justificatif</option>
                            <option value="bulletin_paie">Bulletin de paie</option>
                            <option value="contrat">Contrat</option>
                            <option value="autre" selected>Autre</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Période</label>
                        <div style="display:flex;gap:0.5rem;">
                            <select class="form-control" id="doc-period-month" style="flex:1;">
                                <option value="">Mois</option>
                                <option value="1">Jan</option><option value="2">Fév</option>
                                <option value="3">Mar</option><option value="4">Avr</option>
                                <option value="5">Mai</option><option value="6">Jun</option>
                                <option value="7">Jul</option><option value="8">Aoû</option>
                                <option value="9">Sep</option><option value="10">Oct</option>
                                <option value="11">Nov</option><option value="12">Déc</option>
                            </select>
                            <input type="number" class="form-control" id="doc-period-year" placeholder="Année" style="width:90px;" min="2020" max="2030">
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" onclick="closeModal('upload-document-modal')">Annuler</button>
                <button class="btn btn-primary" onclick="saveDocument()" id="btn-save-document">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="15" height="15"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                    Déposer
                </button>
            </div>
        </div>
    </div>

    <!-- NEW JUSTIFICATIF REQUEST MODAL -->
    <div class="modal-overlay" id="new-justificatif-modal">
        <div class="modal" style="max-width:540px;">
            <div class="modal-header">
                <h2 id="justificatif-modal-title">Nouvelle demande de justificatif</h2>
                <button class="modal-close" onclick="closeModal('new-justificatif-modal')">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                </button>
            </div>
            <div class="modal-body">
                <div class="form-group">
                    <label>Titre de la demande <span style="color:var(--danger);">*</span></label>
                    <input type="text" class="form-control" id="justif-title" placeholder="Ex: Facture téléphone - Janvier 2026">
                </div>
                <div class="form-group">
                    <label>Instructions / Description</label>
                    <textarea class="form-control" id="justif-description" rows="3" placeholder="Précisez les détails de la demande..."></textarea>
                </div>
                <div class="form-group">
                    <label>Date limite (optionnelle)</label>
                    <input type="date" class="form-control" id="justif-deadline">
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" onclick="closeModal('new-justificatif-modal')">Annuler</button>
                <button class="btn btn-primary" onclick="saveJustificatifRequest()">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="15" height="15"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                    Créer la demande
                </button>
            </div>
        </div>
    </div>

    <!-- RESPOND TO JUSTIFICATIF MODAL -->
    <div class="modal-overlay" id="respond-justificatif-modal">
        <div class="modal" style="max-width:500px;">
            <div class="modal-header">
                <h2>Joindre un document</h2>
                <button class="modal-close" onclick="closeModal('respond-justificatif-modal')">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                </button>
            </div>
            <div class="modal-body">
                <p style="font-size:0.88rem;color:var(--muted);margin-bottom:1rem;">Uploadez le document justificatif pour répondre à cette demande.</p>
                <div id="respond-drop-zone" style="border:2px dashed var(--border);border-radius:12px;padding:1.5rem;text-align:center;cursor:pointer;transition:all 0.2s;background:var(--sand);"
                     onclick="document.getElementById('respond-file-input').click()"
                     ondragover="event.preventDefault();this.style.borderColor='var(--emerald)'"
                     ondragleave="this.style.borderColor='var(--border)'"
                     ondrop="event.preventDefault();this.style.borderColor='var(--border)';handleRespondDrop(event)">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="32" height="32" style="color:var(--emerald);margin-bottom:0.5rem;"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                    <p style="font-size:0.85rem;font-weight:600;color:var(--charcoal);">Glissez ou cliquez pour sélectionner</p>
                </div>
                <input type="file" id="respond-file-input" style="display:none;" onchange="handleRespondFileSelect(this)">
                <div id="respond-selected-file" style="display:none;margin-top:0.75rem;padding:0.65rem 1rem;background:var(--success-light);border:1px solid #86efac;border-radius:8px;">
                    <span id="respond-selected-name" style="font-size:0.85rem;font-weight:600;color:var(--charcoal);"></span>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" onclick="closeModal('respond-justificatif-modal')">Annuler</button>
                <button class="btn btn-primary" onclick="submitJustificatifResponse()">Envoyer</button>
            </div>
        </div>
    </div>

    <!-- INVITE CABINET MEMBER MODAL -->
    <div class="modal-overlay" id="invite-member-modal">
        <div class="modal" style="max-width:480px;">
            <div class="modal-header">
                <h2>Inviter un utilisateur</h2>
                <button class="modal-close" onclick="closeModal('invite-member-modal')">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                </button>
            </div>
            <div class="modal-body">
                <div class="form-group">
                    <label>Email <span style="color:red;">*</span></label>
                    <input type="email" class="form-control" id="invite-email" placeholder="collaborateur@cabinet.ma">
                </div>
                <div class="form-group">
                    <label>Nom complet</label>
                    <input type="text" class="form-control" id="invite-name" placeholder="Prénom Nom">
                </div>
                <div class="form-group">
                    <label>Rôle <span style="color:red;">*</span></label>
                    <select class="form-control" id="invite-role">
                        <option value="chef_mission">Chef de mission — supervise un groupe de dossiers</option>
                        <option value="collaborateur">Collaborateur — gère les dossiers qui lui sont assignés</option>
                        <option value="comptable">Comptable — accès aux dossiers assignés</option>
                        <option value="assistant">Assistant — lecture et upload uniquement</option>
                    </select>
                </div>
                <div id="invite-temp-password-box" style="display:none;background:#f0fdf4;border:1px solid #bbf7d0;border-radius:8px;padding:0.75rem 1rem;margin-top:0.5rem;">
                    <p style="font-size:0.82rem;font-weight:600;color:#065f46;margin:0 0 0.3rem;">✅ Invitation envoyée par email. Partagez aussi ce lien si besoin :</p>
                    <code id="invite-temp-password" style="font-size:0.78rem;font-weight:600;color:#059669;background:#dcfce7;padding:0.25rem 0.5rem;border-radius:4px;word-break:break-all;display:block;margin-top:0.3rem;"></code>
                    <p style="font-size:0.75rem;color:#6b7280;margin:0.3rem 0 0;">Le collaborateur recevra un email pour définir son mot de passe.</p>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" onclick="closeModal('invite-member-modal')">Annuler</button>
                <button class="btn btn-primary" id="invite-submit-btn" onclick="submitInviteMember()">Inviter</button>
            </div>
        </div>
    </div>

    <!-- DOSSIER ASSIGNMENT MODAL -->
    <div class="modal-overlay" id="assign-dossiers-modal">
        <div class="modal" style="max-width:500px;">
            <div class="modal-header">
                <h2 id="assign-dossiers-title">Assigner des dossiers</h2>
                <button class="modal-close" onclick="closeModal('assign-dossiers-modal')">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                </button>
            </div>
            <div class="modal-body" style="padding-bottom:0.5rem;">
                <p style="font-size:0.83rem;color:var(--muted);margin-bottom:1rem;">Cochez les dossiers à assigner à ce collaborateur. Les dossiers décochés seront désassignés.</p>
                <div id="assign-dossiers-list" style="max-height:340px;overflow-y:auto;border:1px solid var(--border);border-radius:10px;padding:0.4rem;">
                    <div class="loading-spinner"><div class="spinner"></div></div>
                </div>
            </div>
            <div class="modal-footer" style="margin-top:1rem;">
                <button class="btn btn-secondary" onclick="closeModal('assign-dossiers-modal')">Annuler</button>
                <button class="btn btn-primary" id="assign-dossiers-submit" onclick="submitAssignDossiers()">Enregistrer</button>
            </div>
        </div>
    </div>

    <!-- BANK ACCOUNT MODAL -->
    <div class="modal-overlay" id="bank-account-modal">
        <div class="modal" style="max-width:480px;">
            <div class="modal-header">
                <h2 id="bank-account-modal-title">Nouveau compte bancaire</h2>
                <button class="modal-close" onclick="closeModal('bank-account-modal')">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                </button>
            </div>
            <div class="modal-body">
                <div class="form-group">
                    <label>Nom du compte <span style="color:var(--danger);">*</span></label>
                    <input type="text" class="form-control" id="ba-name" placeholder="Ex: Compte courant Attijariwafa">
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>Banque</label>
                        <input type="text" class="form-control" id="ba-bank-name" placeholder="Ex: Attijariwafa Bank">
                    </div>
                    <div class="form-group">
                        <label>N° de compte</label>
                        <input type="text" class="form-control" id="ba-account-number" placeholder="RIB ou numéro de compte">
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" onclick="closeModal('bank-account-modal')">Annuler</button>
                <button class="btn btn-primary" onclick="saveBankAccount()">Créer le compte</button>
            </div>
        </div>
    </div>

    <!-- CSV IMPORT MODAL -->
    <div class="modal-overlay" id="csv-import-modal">
        <div class="modal" style="max-width:620px;">
            <div class="modal-header">
                <h2>Importer relevé bancaire CSV</h2>
                <button class="modal-close" onclick="closeModal('csv-import-modal')">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                </button>
            </div>
            <div class="modal-body">
                <!-- Account selector -->
                <div class="form-group">
                    <label>Compte bancaire <span style="color:var(--danger);">*</span></label>
                    <select class="form-control" id="import-account-select"></select>
                </div>

                <!-- File drop zone -->
                <div id="csv-drop-zone" style="border:2px dashed #e5e7eb;border-radius:12px;padding:2rem;text-align:center;cursor:pointer;transition:all 0.2s;background:#fafafa;" onclick="document.getElementById('csv-file-input').click()" ondragover="event.preventDefault();this.style.borderColor='#10b981';this.style.background='#f0fdf4';" ondragleave="this.style.borderColor='#e5e7eb';this.style.background='#fafafa';" ondrop="handleCsvDrop(event)">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="36" height="36" style="margin:0 auto 0.75rem;display:block;color:#9ca3af;"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                    <p style="font-size:0.9rem;font-weight:500;color:var(--charcoal);margin:0 0 0.25rem;">Glissez votre fichier CSV ou cliquez ici</p>
                    <p style="font-size:0.78rem;color:var(--muted);margin:0;">Formats supportés : CSV (séparateur ; ou ,) — Attijariwafa, CIH, BMCE, BP, Société Générale</p>
                    <input type="file" id="csv-file-input" accept=".csv,.txt" style="display:none;" onchange="handleCsvFileSelect(event)">
                </div>

                <!-- Preview -->
                <div id="csv-preview" style="display:none;margin-top:1rem;">
                    <div id="csv-preview-info" style="font-size:0.82rem;color:var(--muted);margin-bottom:0.5rem;"></div>
                    <div id="csv-columns-detected" style="background:#f0fdf4;border:1px solid #bbf7d0;border-radius:8px;padding:0.75rem 1rem;font-size:0.82rem;color:#065f46;"></div>
                    <div id="csv-manual-mapping" style="display:none;margin-top:0.75rem;">
                        <p style="font-size:0.82rem;font-weight:600;color:var(--charcoal);margin:0 0 0.5rem;">Mappage manuel des colonnes :</p>
                        <div class="form-row" style="gap:0.5rem;">
                            <div class="form-group" style="flex:1;">
                                <label style="font-size:0.78rem;">Date</label>
                                <select class="form-control" id="map-date" style="font-size:0.8rem;"></select>
                            </div>
                            <div class="form-group" style="flex:2;">
                                <label style="font-size:0.78rem;">Libellé</label>
                                <select class="form-control" id="map-label" style="font-size:0.8rem;"></select>
                            </div>
                            <div class="form-group" style="flex:1;">
                                <label style="font-size:0.78rem;">Débit</label>
                                <select class="form-control" id="map-debit" style="font-size:0.8rem;"><option value="-1">— Aucune —</option></select>
                            </div>
                            <div class="form-group" style="flex:1;">
                                <label style="font-size:0.78rem;">Crédit</label>
                                <select class="form-control" id="map-credit" style="font-size:0.8rem;"><option value="-1">— Aucune —</option></select>
                            </div>
                            <div class="form-group" style="flex:1;">
                                <label style="font-size:0.78rem;">Solde</label>
                                <select class="form-control" id="map-balance" style="font-size:0.8rem;"><option value="-1">— Aucune —</option></select>
                            </div>
                        </div>
                    </div>
