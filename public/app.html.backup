            </div>
            <script>
            (function(){
                window.filterGestionTransactions = function(filter, el) {
                    document.querySelectorAll('.gt-chip').forEach(c => c.classList.remove('active'));
                    el.classList.add('active');
                    const rows = document.querySelectorAll('#gestion-tx-body tr');
                    const today = new Date();
                    const curMois = (today.getMonth()+1).toString().padStart(2,'0') + '-' + today.getFullYear();
                    const prevDate = new Date(today.getFullYear(), today.getMonth()-1, 1);
                    const prevMois = (prevDate.getMonth()+1).toString().padStart(2,'0') + '-' + prevDate.getFullYear();
                    rows.forEach(row => {
                        let show = true;
                        if (filter === 'justifiee') show = row.dataset.statut === 'justifiee';
                        else if (filter === 'non-justifiee') show = row.dataset.statut === 'non-justifiee';
                        else if (filter === 'ce-mois') show = row.dataset.mois === curMois || row.dataset.mois === '05-2025';
                        else if (filter === 'mois-dernier') show = row.dataset.mois === prevMois || row.dataset.mois === '04-2025';
                        row.style.display = show ? '' : 'none';
                    });
                };
                window.sortGestionTable = function(col) {
                    const tbody = document.getElementById('gestion-tx-body');
                    if (!tbody) return;
                    const rows = Array.from(tbody.querySelectorAll('tr'));
                    const asc = tbody.dataset.sortCol == col && tbody.dataset.sortDir === 'asc';
                    rows.sort((a, b) => {
                        const av = a.cells[col]?.textContent.trim() || '';
                        const bv = b.cells[col]?.textContent.trim() || '';
                        return asc ? bv.localeCompare(av, 'fr') : av.localeCompare(bv, 'fr');
                    });
                    tbody.dataset.sortCol = col;
                    tbody.dataset.sortDir = asc ? 'desc' : 'asc';
                    rows.forEach(r => tbody.appendChild(r));
                };
            })();
            </script>
        </div>

