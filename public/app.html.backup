                    </table>
                </div>
            </div>
        </div>

        <!-- GESTION TRANSACTIONS — Dense Table -->
        <div class="view" id="view-gestion-transactions">
            <style>
                .gt-chips { display:flex; gap:8px; flex-wrap:wrap; margin-bottom:16px; }
                .gt-chip { padding:5px 14px; border-radius:20px; font-size:0.78rem; font-weight:500; background:#f3f4f6; color:#374151; border:1px solid #e5e7eb; cursor:pointer; transition:all .15s; user-select:none; }
                .gt-chip:hover { background:#e5e7eb; }
                .gt-chip.active { background:#ecfdf5; color:#047857; border-color:#a7f3d0; font-weight:600; }
                .gt-table-wrap { background:#fff; border-radius:12px; box-shadow:0 1px 3px rgba(0,0,0,.07); overflow:hidden; }
                .gt-table { width:100%; border-collapse:collapse; font-size:0.82rem; }
                .gt-table thead { position:sticky; top:0; z-index:1; }
                .gt-table th { background:#f9fafb; text-align:left; font-size:0.72rem; font-weight:600; color:#6b7280; text-transform:uppercase; letter-spacing:.04em; padding:10px 14px; border-bottom:1px solid #e5e7eb; cursor:pointer; user-select:none; white-space:nowrap; }
                .gt-table th:hover { background:#f3f4f6; color:#374151; }
                .gt-table th .sort-icon { margin-left:4px; opacity:0.4; font-size:0.65rem; }
                .gt-table td { padding:9px 14px; border-bottom:1px solid #f3f4f6; color:#374151; vertical-align:middle; }
                .gt-table tr:last-child td { border-bottom:none; }
                .gt-table tbody tr:nth-child(odd) { background:#fff; }
                .gt-table tbody tr:nth-child(even) { background:#f9fafb; }
                .gt-table tbody tr:hover { background:#ecfdf5 !important; }
                .gt-amount-pos { color:#059669; font-weight:600; }
                .gt-amount-neg { color:#dc2626; font-weight:600; }
                .gt-badge { display:inline-flex; align-items:center; gap:4px; font-size:0.7rem; font-weight:600; padding:2px 9px; border-radius:99px; }
                .gt-badge.justifiee { background:#d1fae5; color:#065f46; }
                .gt-badge.non-justifiee { background:#fef3c7; color:#92400e; }
            </style>
            <div class="page-header">
                <div>
                    <h1>Transactions</h1>
                    <p class="subtitle">Toutes les opérations du compte</p>
                </div>
            </div>

            <!-- Filter chips -->
            <div class="gt-chips">
                <div class="gt-chip active" onclick="filterGestionTransactions('all',this)">Toutes</div>
                <div class="gt-chip" onclick="filterGestionTransactions('justifiee',this)">Justifiées</div>
                <div class="gt-chip" onclick="filterGestionTransactions('non-justifiee',this)">Non justifiées</div>
                <div class="gt-chip" onclick="filterGestionTransactions('ce-mois',this)">Ce mois</div>
                <div class="gt-chip" onclick="filterGestionTransactions('mois-dernier',this)">Mois dernier</div>
            </div>

            <!-- Dense table -->
            <div class="gt-table-wrap">
                <table class="gt-table" id="gestion-tx-table">
                    <thead>
                        <tr>
                            <th onclick="sortGestionTable(0)">Date <span class="sort-icon">↕</span></th>
                            <th onclick="sortGestionTable(1)">Libellé <span class="sort-icon">↕</span></th>
                            <th onclick="sortGestionTable(2)">Montant <span class="sort-icon">↕</span></th>
                            <th>Catégorie</th>
                            <th>Tiers</th>
                            <th>Statut</th>
                        </tr>
                    </thead>
                    <tbody id="gestion-tx-body">
                        <tr data-statut="justifiee" data-mois="05-2025">
