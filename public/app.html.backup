                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" onclick="closeModal('csv-import-modal')">Annuler</button>
                <button class="btn btn-primary" id="btn-confirm-import" onclick="confirmImport()" disabled>Importer les transactions</button>
            </div>
        </div>
