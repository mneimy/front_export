                        <label>RC</label>
                        <input type="text" class="form-control" id="ce-rc" placeholder="000000">
                    </div>
                    <div class="form-group">
                        <label>CNSS</label>
                        <input type="text" class="form-control" id="ce-cnss" placeholder="0000000000">
                    </div>
                </div>
                <div class="form-group">
                    <label>Adresse</label>
                    <input type="text" class="form-control" id="ce-address" placeholder="Adresse complète">
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>Ville</label>
                        <input type="text" class="form-control" id="ce-city" placeholder="Ville">
                    </div>
                    <div class="form-group">
                        <label>Téléphone</label>
                        <input type="text" class="form-control" id="ce-phone" placeholder="+212 5XX XX XX XX">
                    </div>
                </div>
                <div class="form-group">
                    <label>Forme juridique</label>
                    <select class="form-control" id="ce-forme">
                        <option value="">Sélectionner...</option>
                        <option value="SARL">SARL</option>
                        <option value="SA">SA</option>
                        <option value="SNC">SNC</option>
                        <option value="SCS">SCS</option>
                        <option value="SCA">SCA</option>
                        <option value="Auto-entrepreneur">Auto-entrepreneur</option>
                        <option value="Coopérative">Coopérative</option>
                        <option value="Association">Association</option>
                        <option value="EURL">EURL</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>Chef de mission</label>
                    <select class="form-control" id="ce-chef-mission">
                        <option value="">Aucun</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>Pilote PA</label>
                    <input type="text" class="form-control" id="ce-pilote-pa" placeholder="Nom du pilote">
                </div>
