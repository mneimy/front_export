                            <tr><td>Société Atlas</td><td class="td-amount">7 800 MAD</td><td>05/05</td><td><span class="g-badge-retard">+7j</span></td></tr>
                            <tr><td>Cabinet Idris</td><td class="td-amount">3 200 MAD</td><td>10/05</td><td><span class="g-badge-retard">+2j</span></td></tr>
